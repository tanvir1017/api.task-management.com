  api.task-management.com git:(main) cat .env                  
# Database Configuration
# For local development with Docker
DATABASE_URL="postgresql://taskmanager:taskmanager123@localhost:5432/task_management?schema=public"

# For production (replace with your actual database URL)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Application
APP_NAME="Task Management API"
APP_ENV="development"
APP_TIMEZONE="UTC"
APP_HTTP_HOST="0.0.0.0"
APP_HTTP_PORT=4975
APP_GLOBAL_PREFIX="/api"

# URL Versioning
APP_URL_VERSION_ENABLE=true
APP_URL_VERSION_PREFIX="v"
APP_URL_VERSION_VERSION="1"

# JWT Configuration
JWT_ACCESS_SECRET="i8kQWbbej5seETQrbx03KKG5z2BDVSeHla0AiTSNQlYxOMxI0Lvc_WEdFNvn5ADSh7kDzYzLuZReMvPfVbwzPg"
JWT_REFRESH_SECRET="l0_x843ljOq6-mwtXlv6QCLPKuuLYd36rN96saZzd58Yy6bpwZ2eyNmBi1JNJpGnPz7ZFAYDUQK5MvISQeP9RQ"
JWT_ACCESS_EXPIRES_IN="7d"
JWT_REFRESH_EXPIRES_IN="7d"

# System Admin Bootstrap
SYSTEM_ADMIN_EMAIL="admin@example.com"
SYSTEM_ADMIN_USERNAME="systemadmin"
SYSTEM_ADMIN_PASSWORD="123456"
SYSTEM_ADMIN_FULL_NAME="System Administrator"

# Redis (for caching and queues)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0

# Logger
LOGGER_AUTO=true
LOGGER_ENABLE=true
LOGGER_LEVEL="info"
