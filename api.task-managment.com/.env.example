# Database Configuration
# For local development with Docker
DATABASE_URL="postgresql://taskmanager:taskmanager123@localhost:5432/task_management?schema=public"

# For production (replace with your actual database URL)
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public"

# Application
APP_NAME="Task Management API"
APP_ENV="development"
APP_TIMEZONE="UTC"
APP_HTTP_HOST="0.0.0.0"
APP_HTTP_PORT=3000
APP_GLOBAL_PREFIX="/api"

# URL Versioning
APP_URL_VERSION_ENABLE=true
APP_URL_VERSION_PREFIX="v"
APP_URL_VERSION_VERSION="1"

# JWT Configuration
JWT_ACCESS_SECRET="your-access-token-secret-change-this"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-this"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# System Admin Bootstrap
SYSTEM_ADMIN_EMAIL="admin@taskmanagement.local"
SYSTEM_ADMIN_USERNAME="systemadmin"
SYSTEM_ADMIN_PASSWORD="change-this-strong-password"
SYSTEM_ADMIN_FULL_NAME="System Administrator"

# Redis (for caching and queues)
REDIS_HOST="localhost"
REDIS_PORT=6379
REDIS_DB=0

# Logger
LOGGER_AUTO=true
LOGGER_ENABLE=true
LOGGER_LEVEL="info"
